{
  "$schema": "https://opencode.ai/config.json",
  // OpenCode project configuration for Nyaya-Setu
  // https://opencode.ai

  // Instructions appended to every agent session
  "instructions": ["AGENTS.md"],
  
  "agent": {
  "ccms-analyst": {
    "description": "Expert in Indian High Court judgment analysis and administrative action planning.",
    "model": "anthropic/claude-3-5-sonnet", // Or your preferred high-reasoning model
    "prompt": "You are the CCMS-AI Agent. Your goal is to process High Court PDFs and generate actionable government plans. 1. Extract: Case No, Order Date, Parties. 2. Operative Orders: Isolate the judge's specific commands. 3. Timelines: Calculate deadlines from the Order Date (e.g., 'within 4 weeks'). 4. Logic: If the Gov lost, suggest 'Compliance' or 'Appeal'. If the Gov won, suggest 'Record Closing'. 5. Accountability: Assign tasks to Dept heads based on the nature of the order.",
    "tools": {
      "read": true,
      "edit": true,
      "shell": true
    }
  }
}
}
